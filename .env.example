# =====================================================================
# Configuración de despliegue en GCP — copia este archivo a ".env"
#   cp .env.example .env   (y rellena los valores)
# Lo usan tanto deploy-gcp.sh como docker-compose.gcp.yml.
# =====================================================================

# ID del proyecto de Google Cloud (gcloud config get-value project)
PROJECT_ID=mi-proyecto-gcp

# Región y repositorio de Artifact Registry
REGION=europe-west1
REPO=rmi-cluster-repo

# Zona donde se crea la VM de Compute Engine
ZONE=europe-west1-b

# Nombre y tamaño de la VM
VM_NAME=rmi-cluster-vm
MACHINE_TYPE=e2-medium

# IP/DNS PÚBLICA de la VM por la que los AgenteGo externos alcanzan Kafka (puerto 9094).
# Déjalo vacío en el primer despliegue: deploy-gcp.sh lo rellena tras crear la VM.
EXTERNAL_HOST=

# Rangos de origen autorizados a publicar en Kafka (puerto 9094).
# IMPORTANTE: NO uses 0.0.0.0/0 en producción. Pon las IPs de las máquinas con AgenteGo.
# Ejemplo: AGENT_SOURCE_RANGES=203.0.113.10/32,198.51.100.0/24
AGENT_SOURCE_RANGES=0.0.0.0/0
