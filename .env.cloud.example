# =====================================================================
# Variables de RUNTIME para desplegar el servicio Java en cloud (WireGuard).
#
# IMPORTANTE: estos valores NO van dentro de la imagen. Se inyectan al
# DESPLEGAR (Ansible / docker run / compose), DESPUÉS de provisionar la infra
# (cuando ya existen los nombres del WireGuard). La imagen se construye UNA vez
# sin direcciones. Cambiar una dirección = cambiar la env y reiniciar, NO
# reconstruir la imagen.
#
# Sustituye los nombres de ejemplo por los nombres/IP REALES del WireGuard.
# Los puertos NO cambian respecto a local; solo cambian los HOSTS.
# =====================================================================

# ─── rmi-server (una por nodo; cada VM con SU nombre de WireGuard) ─────────────
NODE_ID=node-01
HOST=node-01                                     # nombre/IP WireGuard de ESTA VM
PORT=6100
SEEDS=node-01:6100 node-02:6100 node-03:6100     # nombres WireGuard de los 3 nodos
# CRÍTICO: el hostname que RMI incrusta en el stub. Debe ser el nombre WireGuard
# de ESTA VM, o el cliente/otros nodos no podrán conectarse al objeto remoto.
JVM_OPTS=-Djava.rmi.server.hostname=node-01

# ─── rmi-client (el puente Kafka -> RMI -> Cassandra) ───────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-01:9092,kafka-02:9092   # Kafka del compañero (GCP-A, WireGuard)
SCHEMA_REGISTRY_URL=http://schema-registry:8085        # Schema Registry (WireGuard)
TELEMETRY_TOPIC=telemetry                              # NO cambia (lógico)
CONSUMER_GROUP=telemetry_java_consumers                # NO cambia (lógico)
CASSANDRA_CONTACT_POINTS=cass-01:9042,cass-02:9042     # Cassandra (GCP-A, WireGuard)
CASSANDRA_LOCAL_DC=datacenter1                         # nombre REAL del DC (¡confirmar con el compañero!)
CASSANDRA_KEYSPACE=webhardmon                          # normalmente igual
# Seeds RMI que pasa el cliente como argumentos (mismos nombres WireGuard):
SEEDS=node-01:6100 node-02:6100 node-03:6100

# ─── Agente Go (corre en PCs de usuario, FUERA del WireGuard) ─────────────────
# No usa env: se pasa por flags. Entra por el túnel Cloudflare, no por WireGuard.
#   ./AgenteGo -mode=publisher \
#     -nifi-url="https://ingest.<zona>/telemetry"   # hostname del túnel Cloudflare
#     -codigo="<licencia-real>" -portatil="<nombre-ordenador>"
# (la autenticación del túnel se hace con el Access service token de Cloudflare)
